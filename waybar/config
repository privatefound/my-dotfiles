{
    "layer": "top",
    "position": "top",
    "height": 30,
    "spacing": 4,
    "modules-left": [
        "custom/arch-status",
        "custom/book",
        "hyprland/workspaces",
        "custom/notifications",
        "cpu",
        "memory"
    ],
    "modules-center": [
        "clock",
        "custom/media"
    ],
    "modules-right": [
        "pulseaudio",
        "bluetooth",
        "battery",
        "custom/network-ip",
        "custom/weather",
        "group/tray-drawer",
        "custom/lock",
        "custom/power"
    ],
    "custom/notifications": {
        "format": "{}",
        "return-type": "json",
        "exec": "bash $HOME/.config/hypr/waybar/scripts/waybar-notifications.sh",
        "on-click": "bash -c 'swaync-client -dn; rm -f /tmp/waybar_swaync_notif /tmp/waybar_swaync_app'",
        "tooltip": true,
        "escape": true
    },
    "custom/arch-status": {
        "format": "{}",
        "return-type": "json",
        "interval": 120,
        "exec": "bash $HOME/.config/hypr/waybar/scripts/waybar-helper.sh connection",
        "on-click": "rofi -show drun -config $HOME/.config/hypr/rofi/config.rasi",
        "tooltip": true
    },
    "custom/book": {
        "format": "🕮",
        "tooltip": "Left: AI CMD | Right: Subnet Calc",
        "on-click": "bash $HOME/.config/hypr/rofi/scripts/rofi-ai-cmd.sh",
        "on-click-right": "bash $HOME/.config/hypr/rofi/scripts/rofi-subnet.sh"
    },
    "custom/media": {
        "format": "󰝚 {}",
        "interval": 2,
        "exec": "playerctl metadata --format '{{title}} - {{artist}}' 2>/dev/null || echo 'Nessuna riproduzione'",
        "max-length": 40,
        "on-click": "playerctl play-pause",
        "tooltip": false
    },
    "custom/weather": {
        "format": "{}",
        "interval": 3600,
        "exec": "bash $HOME/.config/hypr/waybar/scripts/waybar-helper.sh weather"
    },
    "hyprland/workspaces": {
        "format": "{name}",
        "on-click": "activate",
        "all-outputs": true
    },
    "clock": {
        "format": "󱑊 {:%H:%M  %d/%m/%Y}",
        "interval": 60,
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "on-click": "gsimplecal"
    },
    "cpu": {
        "format": " {usage}%",
        "interval": 10,
        "tooltip": false,
        "on-click": "missioncenter"
    },
    "memory": {
        "format": " {}%",
        "interval": 30,
        "tooltip": false,
        "on-click": "missioncenter"
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "{icon} {volume}%",
        "format-muted": "󰝟",
        "format-icons": {
            "headphone": "",
            "hands-free": "󰂑",
            "headset": "󰂑",
            "phone": "",
            "portable": "",
            "car": "",
            "default": [
                "",
                ""
            ]
        },
        "on-click": "pavucontrol"
    },
    "bluetooth": {
        "format": " {status}",
        "format-disabled": "󰂲",
        "format-connected": " {device_alias}",
        "on-click": "blueman-manager"
    },
    "custom/network-ip": {
        "format": "{}",
        "return-type": "json",
        "interval": 30,
        "exec": "$HOME/.config/hypr/waybar/scripts/waybar-network-ip.sh",
        "on-click": "$HOME/.config/hypr/waybar/scripts/waybar-network-ip.sh next && pkill -RTMIN+8 waybar",
        "on-click-right": "rofi -show Network -config $HOME/.config/hypr/rofi/config.rasi",
        "signal": 8,
        "tooltip": true
    },
    "group/tray-drawer": {
        "orientation": "inherit",
        "drawer": {
            "transition-duration": 500,
            "children-class": "not-memory",
            "transition-left-to-right": false
        },
        "modules": [
            "custom/tray-icon",
            "tray"
        ]
    },
    "battery": {
        "interval": 60,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": " {capacity}%",
        "format-plugged": " {capacity}%",
        "format-alt": "{icon} {time}",
        "format-icons": [
            "",
            "",
            "",
            "",
            ""
        ]
    },
    "custom/tray-icon": {
        "format": "󱊄",
        "tooltip": false
    },
    "tray": {
        "icon-size": 21,
        "spacing": 12
    },
    "custom/lock": {
        "format": "󰌾",
        "tooltip": false,
        "on-click": "hyprlock"
    },
    "custom/power": {
        "format": "",
        "tooltip": false,
        "on-click": "systemctl poweroff"
    }
}
{
    "layer": "top",
    "position": "top",
    "height": 30,
    "spacing": 4,
    "modules-left": [
        "custom/arch-status",
        "hyprland/workspaces",
        "cpu",
        "memory"
    ],
    "modules-center": [
        "clock",
        "custom/media"
    ],
    "modules-right": [
        "pulseaudio",
        "bluetooth",
        "battery",
        "network",
        "custom/weather",
        "group/tray-drawer",
        "custom/lock",
        "custom/power"
    ],
    "custom/arch-status": {
        "format": "{}",
        "return-type": "json",
        "interval": 120,
        "exec": "bash /home/sec/.config/hypr/waybar/scripts/waybar-helper.sh connection",
        "on-click": "rofi -show drun -config /home/sec/.config/hypr/rofi/config.rasi",
        "tooltip": true
    },
    "custom/media": {
        "format": "¾░ØÜ {}",
        "interval": 2,
        "exec": "playerctl metadata --format '{{title}} - {{artist}}' 2>/dev/null || echo 'Nessuna riproduzione'",
        "max-length": 40,
        "on-click": "playerctl play-pause",
        "tooltip": false
    },
    "custom/weather": {
        "format": "{}",
        "interval": 3600,
        "exec": "bash /home/sec/.config/hypr/waybar/scripts/waybar-helper.sh weather"
    },
    "hyprland/workspaces": {
        "format": "{name}",
        "on-click": "activate",
        "all-outputs": true
    },
    "clock": {
        "format": "¾▒æŖ {:%H:%M  %d/%m/%Y}",
        "interval": 60,
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "on-click": "gsimplecal"
    },
    "cpu": {
        "format": "’Æ╝ {usage}%",
        "interval": 10,
        "tooltip": false
    },
    "memory": {
        "format": "Ņē” {}%",
        "interval": 30,
        "tooltip": false
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "{icon}’Ŗö {volume}%",
        "format-muted": "¾░Ø¤",
        "format-icons": {
            "headphone": "’Ćź",
            "hands-free": "¾░éæ",
            "headset": "¾░éæ",
            "phone": "’éĢ",
            "portable": "’éĢ",
            "car": "’å╣",
            "default": [
                "’Ć¦",
                "’Ć©"
            ]
        },
        "on-click": "pavucontrol"
    },
    "bluetooth": {
        "format": "’Ŗō {status}",
        "format-disabled": "¾░é▓",
        "format-connected": "’Ŗō {device_alias}",
        "on-click": "blueman-manager"
    },
    "network": {
        "format": "{icon}",
        "format-wifi": "¾░ż©",
        "format-ethernet": "¾░łĆ",
        "format-disconnected": "¾░ż«",
        "tooltip-format": "¾░łĆ {ifname} via {gwaddr}",
        "on-click": "rofi -show Network -config /home/sec/.config/hypr/rofi/config.rasi"
    },
    "group/tray-drawer": {
        "orientation": "inherit",
        "drawer": {
            "transition-duration": 500,
            "children-class": "not-memory",
            "transition-left-to-right": false
        },
        "modules": [
            "custom/tray-icon",
            "tray"
        ]
    },
    "battery": {
        "interval": 60,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "’Ś¦ {capacity}%",
        "format-plugged": "’ć” {capacity}%",
        "format-alt": "{icon} {time}",
        "format-icons": [
            "’ēä",
            "’ēā",
            "’ēé",
            "’ēü",
            "’ēĆ"
        ]
    },
    "custom/tray-icon": {
        "format": "¾▒Ŗä",
        "tooltip": false
    },
    "tray": {
        "icon-size": 21,
        "spacing": 12
    },
    "custom/lock": {
        "format": "¾░īŠ",
        "tooltip": false,
        "on-click": "hyprlock"
    },
    "custom/power": {

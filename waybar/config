{
    "layer": "top",
    "position": "top",
    "height": 30,
    "spacing": 4,
    "modules-left": [
        "custom/arch-status",
        "custom/book",
        "hyprland/workspaces",
        "custom/notifications",
        "cpu",
        "memory"
    ],
    "modules-center": [
        "clock",
        "custom/media"
    ],
    "modules-right": [
        "pulseaudio",
        "bluetooth",
        "battery",
        "custom/network-ip",
        "custom/weather",
        "group/tray-drawer",
        "custom/lock",
        "custom/power"
    ],
    "custom/notifications": {
        "format": "{}",
        "return-type": "json",
        "exec": "bash $HOME/.config/hypr/waybar/scripts/waybar-notifications.sh",
        "on-click": "dunstctl history-clear",
        "tooltip": true,
        "escape": true
    },
    "custom/arch-status": {
        "format": "{}",
        "return-type": "json",
        "interval": 120,
        "exec": "bash $HOME/.config/hypr/waybar/scripts/waybar-helper.sh connection",
        "on-click": "rofi -show drun -config $HOME/.config/hypr/rofi/config.rasi",
        "tooltip": true
    },
    "custom/book": {
        "format": "рџ•®",
        "tooltip": "Left: AI CMD | Right: Subnet Calc",
        "on-click": "bash $HOME/.config/hypr/rofi/scripts/rofi-ai-cmd.sh",
        "on-click-right": "bash $HOME/.config/hypr/rofi/scripts/rofi-subnet.sh"
    },
    "custom/media": {
        "format": "у°ќљ {}",
        "interval": 2,
        "exec": "playerctl metadata --format '{{title}} - {{artist}}' 2>/dev/null || echo 'Nessuna riproduzione'",
        "max-length": 40,
        "on-click": "playerctl play-pause",
        "tooltip": false
    },
    "custom/weather": {
        "format": "{}",
        "interval": 3600,
        "exec": "bash $HOME/.config/hypr/waybar/scripts/waybar-helper.sh weather"
    },
    "hyprland/workspaces": {
        "format": "{name}",
        "on-click": "activate",
        "all-outputs": true
    },
    "clock": {
        "format": "у±‘Љ {:%H:%M  %d/%m/%Y}",
        "interval": 60,
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "on-click": "gsimplecal"
    },
    "cpu": {
        "format": "п’ј {usage}%",
        "interval": 10,
        "tooltip": false
    },
    "memory": {
        "format": "о‰¦ {}%",
        "interval": 30,
        "tooltip": false
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "{icon}пЉ” {volume}%",
        "format-muted": "у°ќџ",
        "format-icons": {
            "headphone": "пЂҐ",
            "hands-free": "у°‚‘",
            "headset": "у°‚‘",
            "phone": "п‚•",
            "portable": "п‚•",
            "car": "п†№",
            "default": [
                "пЂ§",
                "пЂЁ"
            ]
        },
        "on-click": "pavucontrol"
    },
    "bluetooth": {
        "format": "пЉ“ {status}",
        "format-disabled": "у°‚І",
        "format-connected": "пЉ“ {device_alias}",
        "on-click": "blueman-manager"
    },
    "custom/network-ip": {
        "format": "{}",
        "return-type": "json",
        "interval": 30,
        "exec": "$HOME/.config/hypr/waybar/scripts/waybar-network-ip.sh",
        "on-click": "$HOME/.config/hypr/waybar/scripts/waybar-network-ip.sh next && pkill -RTMIN+8 waybar",
        "on-click-right": "rofi -show Network -config $HOME/.config/hypr/rofi/config.rasi",
        "signal": 8,
        "tooltip": true
    },
    "group/tray-drawer": {
        "orientation": "inherit",
        "drawer": {
            "transition-duration": 500,
            "children-class": "not-memory",
            "transition-left-to-right": false
        },
        "modules": [
            "custom/tray-icon",
            "tray"
        ]
    },
    "battery": {
        "interval": 60,
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "п—§ {capacity}%",
        "format-plugged": "п‡¦ {capacity}%",
        "format-alt": "{icon} {time}",
        "format-icons": [
            "п‰„",
            "п‰ѓ",
            "п‰‚",
            "п‰Ѓ",
            "п‰Ђ"
        ]
    },
    "custom/tray-icon": {
        "format": "у±Љ„",
        "tooltip": false
    },
    "tray": {
        "icon-size": 21,
        "spacing": 12
    },
    "custom/lock": {
        "format": "у°Њѕ",
        "tooltip": false,
        "on-click": "hyprlock"
    },
    "custom/power": {
        "format": "пЂ‘",
        "tooltip": false,
        "on-click": "systemctl poweroff"
    }
}

[global]
    ### Display ###
    monitor = 0
    follow = mouse
    width = 300
    height = 110
    origin = top-right
    offset = 15x15
    scale = 0
    notification_limit = 5

    ### Progress bar ###
    progress_bar = true
    progress_bar_height = 10
    progress_bar_frame_width = 1
    progress_bar_min_width = 150
    progress_bar_max_width = 300

    ### Text ###
    font = JetBrainsMono Nerd Font 10
    line_height = 0
    markup = full
    format = "<b>%s</b>\n%b"
    alignment = left
    vertical_alignment = center
    show_indicators = yes
    stack_duplicates = true
    hide_duplicate_count = false
    show_age_threshold = 60
    word_wrap = yes
    ellipsize = middle
    ignore_newline = no

    ### Appearance ###
    separator_height = 2
    padding = 12
    horizontal_padding = 12
    text_icon_padding = 12
    frame_width = 3
    frame_color = "#00ff41"
    corner_radius = 12
    separator_color = frame
    sort = yes
    idle_threshold = 120

    ### Icons ###
    icon_position = left
    min_icon_size = 32
    max_icon_size = 64
    icon_path = /usr/share/icons/Adwaita/32x32/status/:/usr/share/icons/Adwaita/32x32/devices/

    ### History ###
    sticky_history = yes
    history_length = 20

    ### Mouse ###
    mouse_left_click = close_current
    mouse_middle_click = do_action, close_current
    mouse_right_click = close_all

[urgency_low]
    background = "#141414"
    foreground = "#ffffff"
    frame_color = "#444444"
    timeout = 10
    script = sh -c "$HOME/.config/hypr/dunst/alert.sh"

[urgency_normal]
    background = "#141414"
    foreground = "#ffffff"
    frame_color = "#00ff41"
    timeout = 10
    script = sh -c "$HOME/.config/hypr/dunst/alert.sh"

[urgency_critical]
    background = "#141414"
    foreground = "#ffffff"
    frame_color = "#ff0000"
    timeout = 0
    script = sh -c "$HOME/.config/hypr/dunst/alert.sh"
